APP_ENV=dev

# Gemini API key (used for LLM field extraction + OCR)
GEMINI_API_KEY=your-gemini-api-key-here

# OCR provider: gemini (uses GEMINI_API_KEY for scanned PDFs) | stub (no-op)
OCR_PROVIDER=gemini

# Antivirus provider: filetype (magic bytes + size validation) | stub (no-op)
AV_PROVIDER=filetype
